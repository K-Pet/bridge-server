# ── Supabase credentials ──────────────────────────────────────────────
BRIDGE_SUPABASE_URL=https://your-project.supabase.co
BRIDGE_SUPABASE_ANON_KEY=eyJ...
BRIDGE_SUPABASE_SERVICE_KEY=eyJ...
BRIDGE_SUPABASE_JWT_SECRET=your-jwt-secret

# ── Webhook / delivery ────────────────────────────────────────────────
BRIDGE_WEBHOOK_SECRET=your-webhook-signing-secret
BRIDGE_DELIVERY_MODE=poll
# BRIDGE_POLL_INTERVAL=5m

# ── Server identity ──────────────────────────────────────────────────
# Unique ID for this home server — used for purchase routing.
BRIDGE_SERVER_ID=my-server

# Auto-pair onboarding — the externally reachable URL of this bridge-server.
# Required for the auto-pair flow during user onboarding.
# In dev, Tiltfile defaults this to http://host.docker.internal:8088.
BRIDGE_EXTERNAL_URL=https://music.example.com

# Human-friendly label for this server shown in the marketplace.
BRIDGE_LABEL=My Music Server
