# Bridge Music Server — production environment template.
# Copy to .env and fill in the values, then `docker compose up -d`.
#
# See docs/PRODUCTION_SETUP.md for the full deployment runbook,
# including how to mint a webhook secret, expose the server publicly,
# and verify end-to-end purchase delivery.

# ─── Required: Supabase project ───────────────────────────────────────
# These come from the Bridge Music marketplace's Supabase project.
# Service-key never crosses the bridge-server boundary — it's used
# server-to-server only.
BRIDGE_SUPABASE_URL=https://your-project-id.supabase.co
BRIDGE_SUPABASE_ANON_KEY=eyJhbGciOi...
BRIDGE_SUPABASE_SERVICE_KEY=eyJhbGciOi...
# JWT secret — used to verify Bearer tokens from iOS / web clients.
# Get it from Supabase Dashboard → Project Settings → API → JWT Secret.
BRIDGE_SUPABASE_JWT_SECRET=

# ─── Required: HMAC secret for webhook authentication ────────────────
# Mint a fresh one per home server (it's never recoverable from the
# bridge-server side once auto-pair runs):
#
#   openssl rand -hex 32
#
BRIDGE_WEBHOOK_SECRET=

# ─── Required for auto-pair (highly recommended) ─────────────────────
# Unique identifier for this home server. The marketplace uses it to
# route purchases. UUIDv4 is fine:
#
#   uuidgen | tr '[:upper:]' '[:lower:]'
#
BRIDGE_SERVER_ID=

# Public origin Supabase will call for webhook delivery and that the
# iOS app will hit for /rest/* streaming. Must be reachable from the
# public internet. Use a real domain + TLS in prod; a Cloudflare
# Tunnel URL is fine for ecosystem testing.
#
# Examples:
#   https://music.example.com
#   https://my-server.trycloudflare.com
BRIDGE_EXTERNAL_URL=

# Friendly name shown in the marketplace UI. Falls back to SERVER_ID
# if blank.
BRIDGE_LABEL=Home Server

# ─── Optional: delivery mode ─────────────────────────────────────────
# webhook (default): Supabase Edge Function pushes purchases to
#                    BRIDGE_EXTERNAL_URL/api/webhook/purchase.
# poll:              bridge-server pulls every BRIDGE_POLL_INTERVAL.
#                    Use this when no public ingress is available.
BRIDGE_DELIVERY_MODE=webhook
BRIDGE_POLL_INTERVAL=5m
