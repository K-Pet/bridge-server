# Bridge Music Server — environment template.
# Copy to .env, fill the four lines below, then `docker compose up -d`.
#
# Full deployment runbook: docs/PRODUCTION_SETUP.md

# ─── Where your music will live on disk ─────────────────────────────
# Defaults to ./data/music inside the repo. Point at a real path on
# your NAS / external drive if you have one.
MUSIC_DIR=./data/music

# ─── Friendly name for this server ──────────────────────────────────
# Shows up in the marketplace UI. Pick anything — "Living Room",
# "Kitchen Server", "Mom's Server", etc.
BRIDGE_LABEL=My Bridge Server

# ─── Public URL the marketplace will deliver purchases to ──────────
# Use a real HTTPS domain or a Cloudflare Tunnel URL. Must be reachable
# from the internet — see PRODUCTION_SETUP.md for the two options.
BRIDGE_EXTERNAL_URL=https://music.example.com

# ─── Operator-supplied secrets (Phase 2 will remove these) ─────────
# These come from the Bridge Music Supabase project. End-users don't
# need to know or rotate them — they exist only because bridge-server
# currently makes service-role writes and verifies JWTs locally. Phase
# 2 moves both behind Edge Functions and these will go away.
BRIDGE_SUPABASE_SERVICE_KEY=
BRIDGE_SUPABASE_JWT_SECRET=

# ─── Optional: delivery mode ────────────────────────────────────────
# webhook (default): Supabase pushes purchases to BRIDGE_EXTERNAL_URL.
# poll:              bridge-server pulls every BRIDGE_POLL_INTERVAL.
# Use poll only if you can't expose BRIDGE_EXTERNAL_URL publicly.
# BRIDGE_DELIVERY_MODE=webhook
# BRIDGE_POLL_INTERVAL=5m

# Server identity (BRIDGE_SERVER_ID) and webhook HMAC secret
# (BRIDGE_WEBHOOK_SECRET) are auto-minted on first boot and persisted
# to /data/bridge/credentials.json. Don't set them here.
